# Copy this to .env for local dev. On Vercel, set these in Project Settings → Environment Variables

ANTHROPIC_API_KEY=your_anthropic_api_key_here
PORT=3000
CLAUDE_MODEL=claude-haiku-4-5

# Hostinger SMTP (used by /lead to email corporate-gifting leads)
HOSTINGER_EMAIL=support@thekuacompany.com
HOSTINGER_EMAIL_PASSWORD=

# Twilio WhatsApp (used by /lead to WhatsApp corporate-gifting leads)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+918904993884

# Supabase (used to log chat history for the admin page)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Admin page password (sent as x-admin-password header)
ADMIN_PASSWORD=
